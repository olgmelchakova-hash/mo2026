ZrA6TggpjLB","executionInfo":{"status":"ok","timestamp":1775810022556,"user_tz":-180,"elapsed":865,"user":{"displayName":"ольга мельчакова","userId":"14970514770594309507"}},"outputId":"87ffab5c-035b-497d-e97e-35a1df4ac7b2"},"execution_count":14,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 640x480 with 6 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":["data.info()"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"lNXobRetsIAP","executionInfo":{"status":"ok","timestamp":1775810036664,"user_tz":-180,"elapsed":14,"user":{"displayName":"ольга мельчакова","userId":"14970514770594309507"}},"outputId":"ca1e4479-6bd5-4107-85a1-0fe9320ea8be"},"execution_count":15,"outputs":[{"output_type":"stream","name":"stdout","text":["<class 'pandas.core.frame.DataFrame'>\n","RangeIndex: 748 entries, 0 to 747\n","Data columns (total 5 columns):\n"," #   Column         Non-Null Count  Dtype\n","---  ------         --------------  -----\n"," 0   Recency        748 non-null    int64\n"," 1   Frequency      748 non-null    int64\n"," 2   Monetary       748 non-null    int64\n"," 3   Time           748 non-null    int64\n"," 4   Donated_blood  748 non-null    int64\n","dtypes: int64(5)\n","memory usage: 29.3 KB\n"]}]},{"cell_type":"code","source":["# Мы можем посмотреть на индивидуальный параметр в Seaborn через коробочную диаграмму.\n","sns.boxplot(x='Donated_blood', y='Time', hue = 'Donated_blood', data=data)\n","# Постройте аналогичные диаграммы для остальных полей"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":467},"id":"fGxOHx6SsQDg","executionInfo":{"status":"ok","timestamp":1775810094176,"user_tz":-180,"elapsed":247,"user":{"displayName":"ольга мельчакова","userId":"14970514770594309507"}},"outputId":"d78309ec-5b9d-4ff9-d995-f9d89866677c"},"execution_count":16,"outputs":[{"output_type":"execute_result","data":{"text/plain":["<Axes: xlabel='Donated_blood', ylabel='Time'>"]},"metadata":{},"exe